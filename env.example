<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Deal Intelligence Live</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="theme-color" content="#0f172a">
<style>
:root{--bg:#f8fafc;--dark:#0f172a;--muted:#64748b;--border:#e2e8f0;--amber:#fbbf24;--green:#16a34a;--blue:#2563eb;--red:#dc2626;--orange:#d97706}
*{box-sizing:border-box}
body{margin:0;background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;color:var(--dark);padding-bottom:28px}
.app{max-width:760px;margin:auto}
.hero{background:linear-gradient(135deg,#0f172a,#1e293b,#334155);color:white;padding:24px 18px 22px;border-bottom-left-radius:30px;border-bottom-right-radius:30px}
.kicker{margin:0;color:var(--amber);font-weight:900;font-size:13px;letter-spacing:.5px}
h1{font-size:28px;line-height:34px;margin:6px 0 8px}
.sub{color:#cbd5e1;font-weight:650;font-size:13px;line-height:19px;margin:0}
.status{display:inline-flex;align-items:center;gap:7px;background:rgba(255,255,255,.12);border-radius:999px;padding:8px 11px;font-size:12px;font-weight:900;margin-top:13px}
.dot{width:9px;height:9px;border-radius:999px;background:#f59e0b}.live .dot{background:#22c55e}
.search{display:flex;gap:8px;margin-top:16px;background:white;border-radius:18px;padding:9px;box-shadow:0 10px 24px rgba(0,0,0,.17)}
.search input{flex:1;border:0;outline:0;font-weight:800;font-size:15px;padding:0 8px;min-width:0}
button,input,textarea,select{font:inherit}
button{cursor:pointer;border:0;font-weight:900}
.primary{background:var(--amber);color:var(--dark);border-radius:14px;padding:13px 15px}
.secondary{background:#e2e8f0;color:var(--dark);border-radius:14px;padding:11px 13px}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;padding:14px 14px 0}
.stat{background:white;border-radius:18px;padding:12px;box-shadow:0 4px 12px rgba(15,23,42,.06)}
.stat small{display:block;color:var(--muted);font-size:10px;font-weight:850}
.stat b{display:block;font-size:20px;margin-top:8px}
.controls{padding:14px;display:flex;gap:8px;overflow:auto;align-items:center}
.chip{border-radius:999px;padding:9px 13px;background:#e2e8f0;color:#334155;white-space:nowrap;font-size:12px}
.chip.active{background:var(--dark);color:white}
.notice{margin:12px 14px 0;background:#fff7ed;border:1px solid #fed7aa;border-radius:18px;padding:12px;color:#92400e;font-size:12px;font-weight:750;line-height:18px}
.grid{padding:14px;display:grid;grid-template-columns:1fr;gap:13px}
.card{background:white;border-radius:24px;padding:14px;box-shadow:0 8px 18px rgba(15,23,42,.08)}
.top{display:flex;gap:13px}
.img{width:106px;height:116px;border-radius:20px;background:linear-gradient(135deg,#fef3c7,#f59e0b);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-weight:950;font-size:25px;position:relative;color:#0f172a;overflow:hidden}
.img img{width:100%;height:100%;object-fit:contain;background:#f8fafc}
.rank{position:absolute;top:8px;left:8px;border-radius:999px;color:white;padding:4px 8px;font-size:11px;font-weight:950}
.info{flex:1;min-width:0}
.title{margin:0;font-size:16px;line-height:21px;font-weight:950;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.brand{margin:5px 0;color:var(--muted);font-size:12px;font-weight:800}
.badges{display:flex;gap:7px;flex-wrap:wrap;margin-top:10px}
.badge{border-radius:999px;padding:6px 9px;font-size:11px;font-weight:950}
.rating{background:#fff7ed}
.price-row{display:flex;align-items:center;justify-content:space-between;margin-top:13px}
.price{font-size:27px;font-weight:950}
.label{color:var(--muted);font-size:11px;font-weight:800;margin-top:2px}
.score{width:64px;height:64px;border-radius:999px;background:#f8fafc;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-direction:column}
.score b{font-size:21px}
.score small{font-size:10px;color:var(--muted);font-weight:850}
.metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;background:#f8fafc;border-radius:18px;padding:10px;margin-top:13px}
.metric b{display:block;font-size:13px}
.metric small{display:block;color:var(--muted);font-size:10px;font-weight:800;margin-top:2px}
.open{width:100%;height:44px;background:var(--dark);color:white;border-radius:15px;margin-top:12px}
.form{padding:14px}
.form-card{background:white;border-radius:24px;padding:15px;box-shadow:0 8px 18px rgba(15,23,42,.08)}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.form-card label{font-size:12px;color:#334155;font-weight:950;margin:10px 0 6px;display:block}
.form-card input,.form-card textarea,.form-card select{width:100%;border:1px solid #cbd5e1;background:#f8fafc;border-radius:14px;padding:11px;font-weight:750}
.form-card textarea{min-height:70px}
.full{grid-column:1/-1}
.hidden{display:none}
.footer{padding:0 14px;color:var(--muted);font-size:12px;line-height:18px}
@media(min-width:700px){.hero{margin-top:12px;border-radius:30px}.grid{grid-template-columns:1fr 1fr}.card{height:100%}}
</style>
</head>
<body>
<div class="app">
  <section class="hero">
    <p class="kicker">Deal Intelligence Live</p>
    <h1>Find Amazon products worth buying today</h1>
    <p class="sub">Live web app with backend. Add Keepa key in deployment environment to activate live Amazon price-history scanning.</p>
    <div id="status" class="status"><span class="dot"></span><b>Checking...</b></div>
    <div class="search">
      <input id="keyword" placeholder="Search product, e.g. power bank" value="wireless earbuds">
      <button id="scanBtn" class="primary">Scan</button>
    </div>
  </section>

  <section class="form">
    <div class="form-card">
      <div class="form-grid">
        <div><label>Marketplace</label><select id="marketplace"><option>IN</option><option>US</option><option>UK</option><option>DE</option><option>JP</option><option>CA</option></select></div>
        <div><label>Price Type</label><select id="priceType"><option>Marketplace New</option><option>Buy Box</option><option>Amazon</option><option>New FBA</option></select></div>
        <div><label>Min Rating</label><input id="minRating" value="4.2" inputmode="decimal"></div>
        <div><label>Min Reviews</label><input id="minReviews" value="100" inputmode="numeric"></div>
        <div><label>Top Results</label><input id="topN" value="15" inputmode="numeric"></div>
        <div><label>Min Score</label><input id="minScore" value="70" inputmode="numeric"></div>
        <div class="full"><label>Optional Manual ASINs</label><textarea id="manualAsins" placeholder="B0XXXXXX, B0YYYYYY"></textarea></div>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="stat"><small>Products</small><b id="total">0</b></div>
    <div class="stat"><small>Excellent</small><b id="excellent">0</b></div>
    <div class="stat"><small>Avg Discount</small><b id="discount">0%</b></div>
    <div class="stat"><small>Avg Trust</small><b id="trust">0</b></div>
  </section>

  <div class="controls">
    <button class="chip active" data-sort="deal_score">Deal Score</button>
    <button class="chip" data-sort="discount_vs_avg_pct">Discount</button>
    <button class="chip" data-sort="authenticity_score">Review Trust</button>
    <button class="chip" data-sort="rating">Rating</button>
  </div>

  <div id="message" class="notice">Ready.</div>
  <section id="products" class="grid"></section>

  <p class="footer">
    Review genuineness is estimated using signals such as rating, review count, price history, and sales rank. It is not a platform-certified guarantee.
  </p>
</div>

<script>
let products = [];
let sortKey = "deal_score";
const $ = id => document.getElementById(id);

function money(v){ return v===null || v===undefined ? "—" : "₹" + Math.round(Number(v)).toLocaleString("en-IN"); }
function num(v,s=""){ return v===null || v===undefined ? "—" : Number(v).toLocaleString("en-IN") + s; }
function compact(v){ if(v===null || v===undefined) return "—"; v=Number(v); if(v>=100000)return(v/100000).toFixed(1)+"L"; if(v>=1000)return(v/1000).toFixed(1)+"K"; return String(v); }
function color(score){ if(score>=85)return"#16a34a"; if(score>=75)return"#2563eb"; if(score>=65)return"#d97706"; return"#dc2626"; }
function initials(t){ return String(t||"DI").split(/\s+/).slice(0,2).map(x=>x[0]?.toUpperCase()).join(""); }
function escapeHtml(s){ return String(s||"").replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m])); }

async function checkHealth(){
  try{
    const r = await fetch("/api/health");
    const h = await r.json();
    const status = $("status");
    if(h.live_key_configured && h.keepa_installed){
      status.classList.add("live");
      status.querySelector("b").textContent = "Live";
    }else{
      status.classList.remove("live");
      status.querySelector("b").textContent = "Demo";
    }
  }catch(e){
    $("status").querySelector("b").textContent = "Offline";
  }
}

async function scan(){
  $("scanBtn").disabled = true;
  $("scanBtn").textContent = "Scanning...";
  $("message").textContent = "Scanning product data...";
  try{
    const payload = {
      keyword: $("keyword").value,
      marketplace: $("marketplace").value,
      price_type: $("priceType").value,
      min_rating: Number($("minRating").value || 4.2),
      min_reviews: Number($("minReviews").value || 100),
      min_score: Number($("minScore").value || 70),
      top_n: Number($("topN").value || 15),
      manual_asins: $("manualAsins").value,
      pages: 2
    };
    const r = await fetch("/api/scan", {method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify(payload)});
    const data = await r.json();
    products = data.products || [];
    $("message").textContent = data.message || "Done.";
    if(data.mode === "live"){
      $("status").classList.add("live");
      $("status").querySelector("b").textContent = "Live";
    }else{
      $("status").classList.remove("live");
      $("status").querySelector("b").textContent = "Demo";
    }
    render();
  }catch(e){
    $("message").textContent = "Error: " + e.message;
  }finally{
    $("scanBtn").disabled = false;
    $("scanBtn").textContent = "Scan";
  }
}

function render(){
  let list = [...products].sort((a,b)=>(Number(b[sortKey])||0)-(Number(a[sortKey])||0)).map((p,i)=>({...p,rank:i+1}));
  $("total").textContent = list.length;
  $("excellent").textContent = list.filter(p=>p.deal_score>=85).length;
  $("discount").textContent = (list.length?Math.round(list.reduce((s,p)=>s+(Number(p.discount_vs_avg_pct)||0),0)/list.length):0)+"%";
  $("trust").textContent = list.length?Math.round(list.reduce((s,p)=>s+(Number(p.authenticity_score)||0),0)/list.length):0;

  if(!list.length){
    $("products").innerHTML = '<div class="notice">No products found. Try lower filters or broader keyword.</div>';
    return;
  }

  $("products").innerHTML = list.map(p=>{
    const c = color(Number(p.deal_score)||0);
    return `<article class="card">
      <div class="top">
        <div class="img">
          ${p.image_url ? `<img src="${p.image_url}" alt="">` : initials(p.title)}
          <span class="rank" style="background:${c}">#${p.rank}</span>
        </div>
        <div class="info">
          <h3 class="title">${escapeHtml(p.title)}</h3>
          <p class="brand">${escapeHtml(p.brand || p.asin || "")}</p>
          <div class="badges">
            <span class="badge" style="background:${c}18;color:${c}">${escapeHtml(p.verdict)}</span>
            <span class="badge rating">⭐ ${num(p.rating)}</span>
          </div>
        </div>
      </div>
      <div class="price-row">
        <div><div class="price">${money(p.current_price)}</div><div class="label">Current Price</div></div>
        <div class="score"><b style="color:${c}">${Math.round(Number(p.deal_score)||0)}</b><small>score</small></div>
      </div>
      <div class="metrics">
        <div class="metric"><b>${compact(p.review_count)}</b><small>Reviews</small></div>
        <div class="metric"><b>${num(p.authenticity_score)}</b><small>Trust</small></div>
        <div class="metric"><b>${money(p.historical_low)}</b><small>Low</small></div>
        <div class="metric"><b>${money(p.avg_price_365d)}</b><small>Avg 365d</small></div>
        <div class="metric"><b>${num(p.near_low_pct,"%")}</b><small>Near Low</small></div>
        <div class="metric"><b>${num(p.discount_vs_avg_pct,"%")}</b><small>Discount</small></div>
      </div>
      <button class="open" onclick="${p.url === "Demo data" ? `alert('Demo product. Add Keepa API key for live Amazon links.')` : `window.open('${p.url}','_blank')`}">Open Product ↗</button>
    </article>`;
  }).join("");
}

document.querySelectorAll("[data-sort]").forEach(btn=>btn.onclick=()=>{
  document.querySelectorAll("[data-sort]").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  sortKey = btn.dataset.sort;
  render();
});
$("scanBtn").onclick = scan;
checkHealth();
scan();
</script>
</body>
</html>
